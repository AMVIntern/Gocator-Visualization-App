# ============================================================
# CHEP PQAS — Runtime Configuration
# This file IS tracked in git. Edit paths/values here; no code changes needed.
# ============================================================

# --- Folder paths watched for new scans ---
FOLDER_IMG_TOP=D:\Gocator_viz\Gocator_Top_Image
FOLDER_IMG_BOTTOM=D:\Gocator_viz\Gocator_Bottom_Image
FOLDER_CSV_TOP=D:\Gocator_viz\Gocator_Top_Result
FOLDER_CSV_BOTTOM=D:\Gocator_viz\Gocator_Bottom_Result

# --- Logos ---
LOGO_LEFT_PATH=D:\Gocator_viz\LOGOS\Splash.png
LOGO_RIGHT_PATH=D:\Gocator_viz\LOGOS\ChepLogo.png

# --- Log file ---
LOG_PATH=D:\Gocator_viz\monitor.log

# --- Shift counter state (restart-safe persistence) ---
STATE_PATH=D:\Gocator_viz\shift_state.json

# --- Shift start times (HH:MM, 24-hour). Used by the per-shift counter. ---
SHIFT1_START=06:00
SHIFT2_START=14:00
SHIFT3_START=22:00

# --- Pairing tolerance: top+bottom results within this many seconds belong
#     to the same pallet (consecutive pallets are >=2.8 s apart) ---
PAIR_TOLERANCE_S=1.5

# --- File-read retries for partially-written files ---
READ_RETRIES=10
READ_RETRY_DELAY_MS=150
